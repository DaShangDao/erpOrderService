<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.order.main.mapper.LogisticsMapper">

    <select id="selectLogisticeByDeptId" resultType="com.order.main.entity.Logistics">
        select l.* from t_logistics l
        left join t_depot d on l.id = d.template_id
        where d.id = #{deptId}
    </select>
</mapper>
